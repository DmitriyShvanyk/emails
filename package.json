{
  "name": "emails",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "mjml index.mjml -o index.html",
    "watch": "nodemon --watch index.mjml -e mjml --exec \"npm run build\"",
    "serve": "live-server --port=3000 --open=index.html --wait=200",
    "dev": "concurrently -k -n MJML,SERVER -c blue,green \"npm:watch\" \"npm:serve\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DmitriyShvanyk/emails.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/DmitriyShvanyk/emails/issues"
  },
  "homepage": "https://github.com/DmitriyShvanyk/emails#readme",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "live-server": "^1.2.2",
    "mjml": "^5.4.0",
    "nodemon": "^3.1.0"
  }
}
